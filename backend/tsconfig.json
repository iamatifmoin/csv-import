{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@groweasy/shared": [
        "../shared/types"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../shared/types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "__tests__"
  ]
}